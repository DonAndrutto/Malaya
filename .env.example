# ── Firebase web config ──────────────────────────────────────────────────────
# These are PUBLIC values (they ship in client code); security is enforced by
# the Firestore/Storage rules in firebase/. They override the project defaults
# baked into lib/firebase.js, so you only need them to point at a different
# Firebase project.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Image source ─────────────────────────────────────────────────────────────
# "cdn" (default) serves product/site images from the live malayajewelrybhutan.com
# CDN. Set to "local" to serve from /public/images after running:
#   node scripts/fetch-images.mjs
NEXT_PUBLIC_IMAGE_SOURCE=cdn
