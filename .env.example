# ── Firebase web config ──────────────────────────────────────────────────────
# These are PUBLIC values (they ship in client code); security is enforced by
# the Firestore/Storage rules in firebase/. They override the project defaults
# baked into lib/firebase.js, so you only need them to point at a different
# Firebase project.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Site ─────────────────────────────────────────────────────────────────────
# Canonical origin of the deployed storefront. Used for metadata (canonical
# URLs, Open Graph), the sitemap, robots.txt and JSON-LD structured data.
NEXT_PUBLIC_SITE_URL=https://malayajewellery.com

# ── E2E tests (Playwright — see e2e/ and .github/workflows/e2e.yml) ───────────
# BASE_URL: deployment to test against (defaults to a local dev server).
# E2E_ADMIN_EMAIL / E2E_ADMIN_PASSWORD: real admin credentials; unlocks the
#   signed-in admin dashboard tests. Keep these in GitHub Actions secrets.
# E2E_ALLOW_WRITES=1: additionally runs the admin↔storefront inventory-sync
#   test, which edits (and restores) one product's sale price in Firestore.
#BASE_URL=
#E2E_ADMIN_EMAIL=
#E2E_ADMIN_PASSWORD=
#E2E_ALLOW_WRITES=

# ── Images ───────────────────────────────────────────────────────────────────
# The storefront is fully self-contained: every product/site image is served
# from this project's own Firebase Storage (URLs saved in Firestore). There is no
# external CDN. Upload imagery from the /admin console (or the seed script below).

# ── Seed script (scripts/fetch-images.mjs) — server-side only, one-off ─────────
# Legacy helper that imports imagery into Firebase Storage and writes the Storage
# URLs into Firestore. Not used by the running site. Uses the Firebase Admin SDK,
# so it needs a service account (console → Project settings → Service accounts →
# Generate new private key). Provide ONE of:
#   GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json
#   FIREBASE_SERVICE_ACCOUNT=/path/to/serviceAccount.json   # or inline JSON
# Optional bucket override (defaults to the project's):
#   FIREBASE_STORAGE_BUCKET=malaya-catalogue.firebasestorage.app
