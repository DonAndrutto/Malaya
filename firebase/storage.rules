rules_version = '2';

// Storage security rules for the Malaya catalogue.
//
// Uploaded images live under:
//   products/{productId}/...   — product photos
//   site/{slot}/...            — hero slides, banners, tiles, logo, portrait
//
// Reads are public (images are served on the storefront). Writes come from the
// signed-in admin (Firebase Auth) and are limited to image files under 15 MB.
//
// The active rules require authentication. Create the studio user in the Firebase
// console (Authentication → Email/Password) before deploying. The seed script
// (scripts/fetch-images.mjs) uses the Admin SDK and bypasses these rules.
// (To temporarily allow anonymous uploads, drop the `request.auth != null` line.)

service firebase.storage {
  match /b/{bucket}/o {

    function isAdminImage() {
      return request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && request.auth != null;   // AUTHENTICATED — signed-in admin only.
    }

    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminImage();
    }

    match /site/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminImage();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
