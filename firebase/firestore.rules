rules_version = '2';

// Firestore security rules for the Malaya catalogue.
//
// Data model:
//   catalogueOverrides/{productId}  — admin edits per product (name, price,
//                                     stock, image URL, …). Merged with the
//                                     base catalogue on the storefront.
//   siteSettings/images             — site-element image URLs (hero, banners…).
//
// Reads are public (the storefront needs them). Writes come from the signed-in
// admin (Firebase Auth email/password — see lib/auth.js).
//
// The active write rules require authentication. Create the studio user in the
// Firebase console (Authentication → Email/Password) before deploying these. The
// seed script (scripts/fetch-images.mjs) uses the Admin SDK and bypasses rules.
// (To temporarily allow anonymous writes again, swap to the `if true` lines.)

service cloud.firestore {
  match /databases/{database}/documents {

    match /catalogueOverrides/{productId} {
      allow read: if true;
      allow write: if request.auth != null;  // AUTHENTICATED — signed-in admin only.
      // allow write: if true;                // OPEN — anyone may edit.
    }

    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;  // AUTHENTICATED — signed-in admin only.
      // allow write: if true;                // OPEN — anyone may edit.
    }

    // Everything else is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
